{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "pnpm install --frozen-lockfile && pnpm build"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/app.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
